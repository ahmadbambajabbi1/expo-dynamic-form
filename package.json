    "axios": ">=0.21.0",
    "date-fns": ">=2.0.0",
    "expo": ">=45.0.0",
    "expo-document-picker": ">=10.0.0",
    "expo-file-system": ">=14.0.0",
    "expo-image-picker": ">=12.0.0",
    "expo-location": ">=12.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "react-hook-form": ">=7.0.0",
    "react-native": ">=0.60.0",
