{
  "name": "expo-dynamic-form",
  "version": "0.14.3",
  "description": "A comprehensive dynamic form library for React Native and Expo",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.cjs",
    "test": "jest --passWithNoTests",
